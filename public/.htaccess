# Plainvoice — easyname Apache static-export hardening
#
# This file is copied verbatim from public/.htaccess into out/.htaccess by
# `next build`, then uploaded to the FTPS root by .github/workflows/deploy.yml.
#
# CSP rationale and the unsafe-inline trade-off are documented in
# docs/security/csp-decisions.md. Issue: yvendive/plainvoice#18.

<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://js.stripe.com 'unsafe-inline' https://static.cloudflareinsights.com; frame-src https://js.stripe.com https://hooks.stripe.com; connect-src 'self' https://plainvoice-pay.yvendive.workers.dev https://api.stripe.com https://cloudflareinsights.com; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://checkout.stripe.com"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
</IfModule>

# Cache-Control — PSI: 85 KiB savings from proper cache lifetimes
#
# Next.js emits content-hashed filenames for all JS/CSS/font chunks
# (e.g., /_next/static/chunks/579-455ac82f.js), so these assets are
# safe to cache indefinitely — a new hash means a new filename.
# Images and HTML use shorter TTLs because their URLs are stable.
<IfModule mod_headers.c>
  # Hashed JS/CSS/font assets — immutable by construction
  <FilesMatch "\.(js|css|woff2|woff|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — stable URLs, change infrequently
  <FilesMatch "\.(png|jpg|jpeg|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML — short TTL so new releases are visible within minutes
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>
